#include "project.h"
#include "Timer.h"

int main(void)
{
    CyGlobalIntEnable; /* Enable global interrupts. */
    Timer_Start(); 
    uint8 overFlow; 
    /* Place your initialization/startup code here (e.g. MyInst_Start()) */
int compteur=0;
    for(;;)
    {    
        overFlow = 0x01 & Timer_ReadStatusRegister();  
        if (overFlow){
            compteur ++; 
            if (compteur == 1000){
                Led1_Write(!Led1_Read()); 
                compteur = 0; 
            }
        }
        /* Place your application code here. */
    }
}

