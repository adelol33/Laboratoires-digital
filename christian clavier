#include "project.h"
#include "keypad.h"

int main(void)
{
    CyGlobalIntEnable; /* Enable global interrupts. */

    /* Place your initialization/startup code here (e.g. MyInst_Start()) */
    LCD_Start();
    for(;;)
    {
        CyDelay(100);
        char key = keypadScan(); 
        int a = 0; 
        int b = 0; 
        
        if (key != 'z') {
            LCD_Position(a,b); 
            LCD_PutChar(key);
            if (a != 8)
                a += 1; 
            else
            {   
                a = 0; 
            }
            if (b != 8)
                b += 1; 
            else
            {b = 0;
               }
                
        }
       /* Place your application code here. */
    }
}

