#include "project.h"
#include "math.h"
float sinWave[100];
int in = 0;
int main(void)
 
{
    CyGlobalIntEnable; /* Enable global interrupts. */
    Timer_Start();
    VDAC_Start(); 
    /* Place your initialization/startup code here (e.g. MyInst_Start()) */
    for (int i =0; i<100; i++) 
    {sinWave[i] = sin(2*M_PI*i/100); 
    }
    uint8 overflow; 
    for(;;)
    {    
       overflow = 0x80 & Timer_ReadStatusRegister(); 
    if (overflow) {
        float sample = sinWave[in]; 
        VDAC_SetValue(sample);
        in ++; 
        if (in == 100) {
            in = 0; 
        }
    
    }
        /* Place your application code here. */
    }
}

